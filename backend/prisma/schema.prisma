generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  level           Int      @default(1)
  currentXp       Int      @default(0)
  
  // STATISTICI REALE (inlocuiesc calculul automat)
  strength        Int      @default(0)
  agility         Int      @default(0)
  intellect       Int      @default(0)

  lastActiveDate  DateTime @default(now()) @db.Date

  habits          Habit[]
  habitLogs       HabitLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("users")
}

model Habit {
  id               String   @id @default(cuid())
  userId           String
  name             String
  description      String?
  xpReward         Int      @default(10)
  
  // LEGAM HABIT-UL DE O CLASA/ATRIBUT ("strength", "agility" sau "intellect")
  attribute        String   @default("strength") 
  
  isCompletedToday Boolean  @default(false)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs             HabitLog[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id           String   @id @default(cuid())
  habitId      String
  userId       String
  xpAwarded    Int
  completedAt  DateTime @default(now())

  habit        Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([habitId])
  @@map("habit_logs")
}